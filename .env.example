# Firebase configuration (already present in your .env)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google OAuth client ID for Firebase Authentication (web client)
# Example: 1234567890-abcdefg.apps.googleusercontent.com
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Public base URL for OAuth redirect (must match Google Console redirect)
# Example: https://yourdomain.com/taskMission/
VITE_AUTH_REDIRECT_URL=
